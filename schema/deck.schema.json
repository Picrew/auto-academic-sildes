{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Academic Deck Compiler deck.yaml",
  "type": "object",
  "required": ["deck_id", "title", "slides"],
  "properties": {
    "deck_id": { "type": "string" },
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "visual_grammar": {
      "type": "string",
      "enum": [
        "academic-homepage-grid",
        "atlas-marginalia",
        "broadsheet-data-room",
        "broadside-lab",
        "catalog-atelier",
        "chromatic-research-map",
        "cobalt-research-grid",
        "couture-exhibition",
        "dark-lab-notebook",
        "editorial-profile",
        "evidence-atelier",
        "fathom-research-brief",
        "folio-swiss-noir",
        "forest-editorial-brief",
        "gallery-proof-room",
        "highsense-gallery",
        "huashu-build-board",
        "huashu-editorial-lab",
        "huashu-issue-broadsheet",
        "ia-research-archive",
        "jetset-theory-grid",
        "js-editorial-cascade",
        "keynote-evidence-wall",
        "lab-trace-ledger",
        "maison-research-catalog",
        "mono-ink-ledger",
        "monograph-review",
        "neo-grid-lab",
        "object-study-wall",
        "paper-atlas",
        "pentagram-gridnote",
        "prism-clean-room",
        "prism-dossier",
        "prism-newsroom-index",
        "prism-publication-stack",
        "prism-workbench-index",
        "raw-grid-research",
        "signal-intelligence-brief",
        "stamen-data-map",
        "stencil-field-tablet",
        "sumi-research-scroll",
        "swiss-systems",
        "systems-field-manual",
        "takram-research-system",
        "vellum-research-note"
      ]
    },
    "footer": { "type": "string" },
    "contact": { "type": "string" },
    "assets_dir": { "type": "string" },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide" }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "crop": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "w": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "h": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
      }
    },
    "callout": {
      "type": "object",
      "required": ["x", "y", "text"],
      "properties": {
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "text": { "type": "string" }
      }
    },
    "evidence": {
      "type": ["object", "null"],
      "required": ["image", "crop", "caption", "source"],
      "properties": {
        "image": { "type": "string" },
        "crop": { "$ref": "#/$defs/crop" },
        "caption": { "type": "string" },
        "source": { "type": "string" },
        "callouts": { "type": "array", "maxItems": 3, "items": { "$ref": "#/$defs/callout" } }
      }
    },
    "slide": {
      "type": "object",
      "required": ["kind", "title"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["cover", "thesis", "map", "split", "process", "evidence", "matrix", "system", "loop", "product", "stack", "close"]
        },
        "kicker": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "layout": {
          "type": "string",
          "enum": [
            "artifact-dossier",
            "artifact-ledger",
            "artifact-marginalia",
            "artifact-rail",
            "artifact-showcase",
            "content-bento",
            "content-field-manual",
            "content-label-board",
            "content-marginalia",
            "content-workbench-index",
            "cover-poster-grid",
            "cover-source-rail",
            "cover-title-card",
            "cover-title-wall",
            "matrix-ledger",
            "matrix-map",
            "metrics-led",
            "metrics-ledger",
            "proof-atlas-spread",
            "proof-dossier",
            "proof-gallery-split",
            "proof-led",
            "proof-ledger",
            "proof-marginalia",
            "proof-showcase",
            "proof-stage",
            "spine-map",
            "text-two-col"
          ]
        },
        "bullets": { "type": "array", "items": { "type": "string" } },
        "metrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "labels": { "type": "array", "items": { "type": "string" } },
        "image": { "type": ["string", "null"] },
        "evidence": { "$ref": "#/$defs/evidence" },
        "note": { "type": "string" }
      }
    }
  }
}
